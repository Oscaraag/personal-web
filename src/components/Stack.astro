---
import { stack } from '../data/stack';
import T from './T.astro';
---
<section class="section" id="stack">
  <div class="wrap">
    <div class="sec-head reveal">
      <span class="sec-num">03 — <T as="span" es="Instrumental" en="Instruments" /></span>
      <T as="h2" class="sec-title" es="Instrumental de a bordo" en="Onboard instruments" />
    </div>

    <div class="stack-grid">
      {
        stack.map((card) => (
          <div class:list={['stack-card', 'reveal', card.delay]}>
            <div class="ico">
              <svg
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="1.8"
                stroke-linecap="round"
                stroke-linejoin="round"
                set:html={card.icon}
              />
            </div>
            <T as="h3" es={card.title.es} en={card.title.en} />
            <div class="chips">
              {card.chips.map((c) => (
                <T as="span" class="chip" es={c.es} en={c.en} />
              ))}
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>
